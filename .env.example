# Copy this file to `.env` and fill in your real values.
# Never commit `.env` or any real API keys.

# Public site URL used for SEO/canonical metadata if needed
PUBLIC_SITE_URL=https://studionorthworkshop.com

# Do not use secret API keys directly in this static frontend.
# Put secrets in a backend server or serverless function instead.
API_BASE_URL=http://localhost:3000/api

# Example server-side secret names
OPENAI_API_KEY=your_server_side_key_here
STRIPE_SECRET_KEY=your_server_side_key_here
EMAIL_API_KEY=your_server_side_key_here
